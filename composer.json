{
    "name": "fballiano/module-klarna",
    "description": "Klarna Payments integration for Maho",
    "type": "maho-module",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "*",
        "mahocommerce/maho": ">=26.5",
        "mahocommerce/maho-phpstan-plugin": "*",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-deprecation-rules": "*",
        "phpstan/phpstan-strict-rules": "*",
        "rector/rector": "*"
    },
    "config": {
        "allow-plugins": {
            "mahocommerce/maho-composer-plugin": true
        },
        "platform": {
            "php": "8.3"
        }
    }
}
